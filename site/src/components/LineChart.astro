---
// Linha + área a partir de pares [rótulo, valor]. Destaque no ponto final.
// SSG determinístico (toFixed) → snapshot-test estável. Substitui _linha.
import type { Pair } from '../lib/schema';
interface Props {
  data: Pair[];
  color?: string;
  id?: string;      // id único do gradiente (evita colisão com vários no mesmo doc)
  unit?: string;
}
const { data, color = 'var(--c1)', id = 'ln', unit = '' } = Astro.props;

const W = 520, H = 200, padL = 32, padR = 24, padT = 22, padB = 30;
const vals = data.map((d) => d[1]);
const max = Math.max(...vals), min = Math.min(...vals, 0), rng = max - min || 1;
const n = data.length;
const x = (i: number) => +(padL + (i / (n - 1)) * (W - padL - padR)).toFixed(1);
const y = (v: number) => +(padT + (1 - (v - min) / rng) * (H - padT - padB)).toFixed(1);

const pts = data.map((d, i) => `${x(i)},${y(d[1])}`);
const line = pts.join(' ');
const area = `${padL},${y(min)} ${line} ${x(n - 1)},${y(min)}`;
const last = data[n - 1];
// picos = máximos locais (val > vizinho esquerdo e >= direito); rotula o valor no topo.
// exclui o último ponto (já rotulado). ly evita cortar o rótulo no topo do viewBox.
// proeminência: ignora bumps pequenos (só máximo local >= 30% do máximo).
const peaks = data
  .map((_, i) => i)
  .filter((i) => i > 0 && i < n - 1 && data[i][1] > data[i - 1][1] && data[i][1] >= data[i + 1][1] && data[i][1] >= max * 0.3);
const ly = (v: number) => Math.max(10, y(v) - 9);
// rótulos do eixo x: primeiro, meio, último
const ticks = [0, Math.floor((n - 1) / 2), n - 1];
---
<svg viewBox={`0 0 ${W} ${H}`} width="100%" role="img" aria-label="Série temporal">
  <defs>
    <linearGradient id={id} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color={color} stop-opacity="0.28" />
      <stop offset="1" stop-color={color} stop-opacity="0" />
    </linearGradient>
  </defs>
  <line class="gline" x1={padL} y1={y(max)} x2={W - padR} y2={y(max)} />
  <line class="gline" x1={padL} y1={y(min)} x2={W - padR} y2={y(min)} />
  <polygon points={area} fill={`url(#${id})`} />
  <polyline points={line} fill="none" stroke={color} stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" />
  {peaks.map((i) => (
    <g>
      <circle cx={x(i)} cy={y(data[i][1])} r="3.5" fill={color} stroke="var(--surface)" stroke-width="2" />
      <text x={x(i)} y={ly(data[i][1])} text-anchor="middle" class="barlbl">{data[i][1].toLocaleString('pt-BR')}{unit}</text>
    </g>
  ))}
  <circle cx={x(n - 1)} cy={y(last[1])} r="4.5" fill={color} stroke="var(--surface)" stroke-width="2.5" />
  <text x={W - padR} y={y(last[1]) - 9} text-anchor="end" class="barlbl">{last[1].toLocaleString('pt-BR')}{unit}</text>
  {ticks.map((i) => (
    <text x={x(i)} y={H - 8} text-anchor={i === 0 ? 'start' : i === n - 1 ? 'end' : 'middle'} class="axis">{data[i][0]}</text>
  ))}
</svg>
