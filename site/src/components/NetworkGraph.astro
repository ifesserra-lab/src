---
// Grafo de colaboração — espelha a "Rede de colaboração" (painel) e o
// "Trabalhou com" (ego, extensionista). Layout radial determinístico (bom p/ SSG):
// modo padrão = nós num círculo; modo ego = nó 0 no centro, resto em anel.
// Espessura da aresta ∝ peso; nome no <title> (hover). Sem dependência externa.
interface Props {
  nodes: string[];
  edges: number[][]; // [i, j, peso]
  ego?: boolean;
  height?: number;
}
const { nodes, edges, ego = false, height = 320 } = Astro.props;
const W = 640, H = height;
const cx = W / 2, cy = H / 2;
const R = Math.min(W, H) / 2 - 60;

// grau ponderado por nó (p/ raio do círculo)
const grau = nodes.map(() => 0);
for (const [i, j, w] of edges) { grau[i] += w; grau[j] += w; }
const gmax = Math.max(...grau, 1);

const pos = nodes.map((_, idx) => {
  if (ego && idx === 0) return { x: cx, y: cy };
  const n = ego ? nodes.length - 1 : nodes.length;
  const k = ego ? idx - 1 : idx;
  const ang = (2 * Math.PI * k) / (n || 1) - Math.PI / 2;
  return { x: cx + R * Math.cos(ang), y: cy + R * Math.sin(ang) };
});
const wmax = Math.max(...edges.map((e) => e[2]), 1);
const primeiroNome = (s: string) => (s || '').split(/\s+/)[0];
---
<div class="ng">
  <svg viewBox={`0 0 ${W} ${H}`} width="100%" role="img" aria-label="Grafo de colaboração" style={`max-width:${W}px`}>
    {edges.map(([i, j, w]) => (
      <line x1={pos[i].x} y1={pos[i].y} x2={pos[j].x} y2={pos[j].y}
        stroke="var(--c1)" stroke-opacity={0.18 + 0.5 * (w / wmax)}
        stroke-width={1 + 3.5 * (w / wmax)} stroke-linecap="round">
        <title>{nodes[i]} — {nodes[j]}: {w} ação(ões)</title>
      </line>
    ))}
    {nodes.map((nome, idx) => {
      const r = ego && idx === 0 ? 16 : 6 + 10 * (grau[idx] / gmax);
      const isCenter = ego && idx === 0;
      return (
        <g>
          <circle cx={pos[idx].x} cy={pos[idx].y} r={r}
            fill={isCenter ? 'var(--c1)' : 'var(--c2)'} stroke="var(--surface)" stroke-width="2">
            <title>{nome}{grau[idx] ? ` — ${grau[idx]} colaboração(ões)` : ''}</title>
          </circle>
          <text x={pos[idx].x} y={pos[idx].y - r - 4} text-anchor="middle" class="tl-s"
            style="pointer-events:none">{primeiroNome(nome)}</text>
        </g>
      );
    })}
  </svg>
</div>

<style>
  .ng { overflow-x: auto; }
  .ng svg { display: block; margin: 0 auto; }
</style>
