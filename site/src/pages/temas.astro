---
import Base from '../layouts/Base.astro';
import TreemapDrill from '../components/TreemapDrill.astro';
import { getTemas } from '../lib/data';
import { withBase } from '../lib/url';

const t = getTemas();
const totalAtend = t.temas.reduce((s, c) => s + c.publico, 0) || 1;
const totalPessoas = t.temas.reduce((s, c) => s + c.pessoas, 0) || 1;
const maxPublico = Math.max(...t.temas.map((c) => c.publico), 1);
const fmt = (n: number) => n.toLocaleString('pt-BR');
---
<Base title="Temas" description="O que a extensão faz, por tema — clusters derivados do texto das ações." active="temas">
  <div class="wrap">
    <p class="crumb">Páginas / <b>Temas</b></p>
    <h1>Temas &amp; clusters da extensão</h1>
    <p class="sub">O que a extensão faz, por tema — do texto das ações</p>

    <div class="card" style="margin-top:14px">
      <h2 style="margin-top:0">Mapa: atendimentos por tema × tipo</h2>
      <p class="sec-desc">Cada bloco é um tema (área = atendimentos de público), subdividido pelos tipos de ação. Clique num tema para abrir as iniciativas; os cards abaixo trazem coordenadores e exemplos de cada tema.</p>
      <div style="margin-top:14px"><TreemapDrill payload={t.treemap} height={420} /></div>
    </div>

    <p class="section-title">Detalhe por tema</p>
    {t.temas.map((c) => {
      const pctA = Math.round((c.publico / totalAtend) * 100);
      const pctP = Math.round((c.pessoas / totalPessoas) * 100);
      const w = ((c.publico / maxPublico) * 100).toFixed(1);
      return (
        <div class="card" style="margin-top:14px">
          <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap">
            <h2 style="margin:0">{c.tema}</h2>
            <span class="sec-desc" style="margin:0">{c.acoes} ações · <b>{fmt(c.publico)}</b> atendimentos ({pctA}%) · <b>{fmt(c.pessoas)}</b> pessoas distintas ({pctP}%)</span>
          </div>
          <div class="bt" style="background:var(--parchment);border-radius:6px;height:8px;margin:8px 0 12px">
            <span style={`display:block;height:100%;width:${w}%;background:var(--series-1);border-radius:6px`}></span>
          </div>
          {c.resumo && (
            <p style="margin:0 0 10px;font-size:14px;line-height:1.55">{c.resumo} <small style="color:var(--muted)">(resumo por IA)</small></p>
          )}
          {c.coordenadores.length > 0 && (
            <p class="sec-desc" style="margin:0 0 4px">
              <b>Coordenadores:</b>{' '}
              {c.coordenadores.map((co, i) => (
                <>
                  {i > 0 && ' · '}
                  {co.slug
                    ? <a class="lk" href={withBase(`/extensionistas/${co.slug}.html`)}>{co.nome}</a>
                    : <span>{co.nome}</span>}
                  {' '}({co.n})
                </>
              ))}
            </p>
          )}
          {c.exemplos.length > 0 && (
            <p class="sec-desc" style="margin:0">
              <b>Exemplos:</b>{' '}
              {c.exemplos.map((ex, i) => (
                <>
                  {i > 0 && ' · '}
                  <a class="lk" href={withBase(`/acoes/${ex.acao_id}.html`)}>{ex.titulo}</a>
                </>
              ))}
            </p>
          )}
        </div>
      );
    })}
  </div>
</Base>
